<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order - Velox Host</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-logo">⚡ Velox Host</div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="#pricing">Pricing</a>
            <a href="/order">Order</a>
            <% if (user) { %>
                <a href="/dashboard" class="btn btn-primary">Dashboard</a>
            <% } else { %>
                <a href="/login" class="btn btn-discord">Login with Discord</a>
            <% } %>
        </div>
    </nav>

    <section class="order-section">
        <h2 class="section-title">Place Your <span>Order</span></h2>
        <div class="form-card">
            <form method="POST" action="/order">
                <div class="form-group">
                    <label>Your Name</label>
                    <input type="text" name="name" placeholder="Enter your name" required>
                </div>
                <div class="form-group">
                    <label>Discord Username</label>
                    <input type="text" name="discord" placeholder="e.g. ardakospc" required>
                </div>
                <div class="form-group">
                    <label>Bot Type</label>
                    <select name="bot_type" required>
                        <option value="">Select bot type...</option>
                        <option value="custom">Custom Bot for Server</option>
                        <option value="security">Security Bot</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Hosting Plan</label>
                    <select name="plan" required>
                        <option value="">Select a plan...</option>
                        <option value="weekly">Weekly - €5</option>
                        <option value="monthly">Monthly - €10</option>
                        <option value="yearly">Yearly - €50</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Payment Method</label>
                    <select name="payment" required>
                        <option value="">Select payment method...</option>
                        <option value="paysafe">Paysafe</option>
                        <option value="paypal">PayPal</option>
                        <option value="crypto">Crypto</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Additional Notes</label>
                    <textarea name="notes" placeholder="Any special requirements..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:14px;">Submit Order</button>
            </form>
        </div>
    </section>

    <footer class="footer">
        <p>&copy; 2026 Velox Host. All rights reserved.</p>
    </footer>
</body>
</html>
